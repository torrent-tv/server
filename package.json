{
  "name": "@torrent-tv/server",
  "version": "0.8.13",
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "scripts": {
    "start": "node ./server.js",
    "dev": "node --inspect --experimental-network-inspection ./server.js",
    "patch": "npm version patch && npm run docker:publish && git push --follow-tags",
    "minor": "npm version minor && npm run docker:publish && git push --follow-tags",
    "major": "npm version major && npm run docker:publish && git push --follow-tags",
    "docker:build": "docker build -t ghcr.io/torrent-tv/server:$npm_package_version -t ghcr.io/torrent-tv/server:latest .",
    "docker:push": "docker push ghcr.io/torrent-tv/server:$npm_package_version && docker push ghcr.io/torrent-tv/server:latest",
    "docker:publish": "npm run docker:build && npm run docker:push"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/websocket": "^11.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/static": "^9.1.3",
    "fastify": "^5.8.5",
    "get-port": "^7.1.0",
    "hls.js": "^1.6.0"
  }
}
